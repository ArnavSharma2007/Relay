# RELAY Production Environment Variables
# Copy to server/.env and client/.env.local for local dev

# ─── SERVER (Railway) ───────────────────────────────────────────

# Required — get free Postgres at https://neon.tech
# Or use local Docker: postgresql://relay:relay@localhost:5432/relay
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay

# Required — generate: openssl rand -hex 32
JWT_SECRET=your-long-random-secret-here

# Required — your Vercel frontend URL (comma-separated for multiple)
CLIENT_URL=https://relay.vercel.app,http://localhost:5173

# Required for WebRTC — Railway public IP or domain
MEDIASOUP_ANNOUNCED_IP=your.railway.app

# Storage: "local" for dev, "s3" for production (Cloudflare R2)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage

# Cloudflare R2 (S3-compatible) — for production recordings
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=relay-storage
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://pub-xxx.r2.dev

# TURN server (optional, needed for remote customers behind NAT)
# TURN_URLS=turn:turn.example.com:3478
# TURN_USERNAME=relay
# TURN_CREDENTIAL=your-turn-password

# SMTP Configuration (optional, falls back to mock console logs & Ethereal test accounts)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="RELAY Support <your-email@gmail.com>"

PORT=3001
NODE_ENV=production

# ─── CLIENT (Vercel) ────────────────────────────────────────────

# Required in production — your Railway backend URL
VITE_API_URL=https://your-app.up.railway.app/api
VITE_SOCKET_URL=https://your-app.up.railway.app
